# ===========================================
# NEON DATABASE CONFIGURATION (REQUIRED)
# ===========================================

# Neon PostgreSQL Connection String
# Get this from the Neon Console: https://console.neon.tech
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# ===========================================
# AI CONFIGURATION (REQUIRED for AI features)
# ===========================================

# Cerebras API Key (primary LLM for blog generation)
# Get from: https://cloud.cerebras.ai/
CEREBRAS_API_KEY=csk-your-key-here

# Gemini AI API Key (backup/fallback LLM)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...

# ===========================================
# OPTIONAL INTEGRATIONS
# ===========================================

# Upstash Redis (for rate limiting - optional)
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Cloudinary (for image optimization - optional)
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...

# ===========================================
# FEATURE FLAGS
# ===========================================

# Database provider: 'neon' (default)
VITE_DATABASE_PROVIDER=neon
