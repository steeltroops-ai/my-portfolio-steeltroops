#!/usr/bin/env sh

# Husky Pre-Push Hook
# ====================
# Runs before any `git push`.
# Responsibilities:
#   1. Detect whether real code (non-docs) changed vs origin/main
#   2. If code changed: bump version locally, commit it, then allow push to proceed
#   3. Run build integrity check to catch compile-time errors before they land on GitHub

set -e

REMOTE="origin"
BRANCH="main"

# Determine what changed between local HEAD and remote main
CHANGED=$(git diff --name-only "$REMOTE/$BRANCH" HEAD 2>/dev/null || git diff --name-only HEAD)

# Check if anything beyond docs/metadata changed
CODE_CHANGED=$(echo "$CHANGED" | grep -vE "^(docs/|.*\.md$|\.github/|\.husky/|\.vscode/|public/build-meta\.json|package\.json|bun\.lock|README\.md)" || true)

if [ -n "$CODE_CHANGED" ]; then
  echo ">> Codebase changes detected. Running version bump..."

  # Bump the version locally (writes package.json + build-meta.json)
  PUSH_MODE=true node scripts/version-bump.js

  # Stage and amend the version files into the current HEAD commit
  # (amend so the version bump is part of your commit, not a separate one)
  git add package.json public/build-meta.json

  # Only commit if there are actually staged changes (i.e. version did change)
  if ! git diff --cached --quiet; then
    git commit --no-verify -m "chore(release): bump version [skip ci]"
    echo ">> Version bumped and committed."
  else
    echo ">> Version unchanged (doc-only path). No commit needed."
  fi

  echo ">> Running build integrity check..."
  bun run build
  echo ">> Build passed. Proceeding with push."

else
  echo ">> Documentation/metadata-only changes. Skipping version bump and build."
fi
