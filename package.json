{
  "name": "my-portfolio-steeltroops",
  "private": true,
  "version": "2.0.4",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:vite\"",
    "dev:vite": "vite --host",
    "dev:api": "bun --watch server/local-api.js",
    "dev:vercel": "vercel dev",
    "version-bump": "node scripts/version-bump.js",
    "build": "bun run version-bump && bun run sitemap && vite build",
    "preview": "vite preview",
    "lint": "bunx eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "init-admin": "node scripts/init-admin.js",
    "hash-password": "node scripts/hash-password.js",
    "update-password": "node scripts/update-admin-password.js",
    "sitemap": "node scripts/generate-sitemap.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@cerebras/cerebras_cloud_sdk": "^1.64.1",
    "@neondatabase/serverless": "^1.0.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.18",
    "cors": "^2.8.6",
    "dompurify": "^3.3.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^12.34.0",
    "highlight.js": "^11.11.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lenis": "^1.3.17",
    "prop-types": "^15.8.1",
    "quill": "^2.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^7.13.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ua-parser-js": "^2.0.9",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "husky": "^9.1.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "terser": "^5.46.0",
    "vite": "7.3.1",
    "vite-imagetools": "^9.0.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
