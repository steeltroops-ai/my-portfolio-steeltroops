{
  "name": "my-portfolio-steeltroops",
  "private": true,
  "version": "2.3.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"bun run dev:api\" \"bun run dev:vite\"",
    "dev:vite": "vite --host",
    "dev:api": "bun --watch server/local-api.js",
    "dev:vercel": "vercel dev",
    "version-bump": "node scripts/version-bump.js",
    "build": "bun run version-bump && bun run sitemap && vite build",
    "preview": "vite preview",
    "lint": "bunx eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "init-admin": "node scripts/init-admin.js",
    "hash-password": "node scripts/hash-password.js",
    "update-password": "node scripts/update-admin-password.js",
    "sitemap": "node scripts/generate-sitemap.js",
    "verify-tracking": "node scripts/verify-tracking.js",
    "test-tracking-init": "node scripts/test-tracking-init.js",
    "test-page-view-tracking": "node scripts/test-page-view-tracking.js",
    "test-behavioral-tracking": "node scripts/test-behavioral-tracking.js",
    "test-forensic-fingerprinting": "node scripts/test-forensic-fingerprinting.js",
    "test-admin-bypass": "node scripts/test-admin-bypass.js",
    "check-integrity": "bun run scripts/check-data-integrity.js",
    "run-migrations": "node scripts/run-migrations.js",
    "test-init-action": "bun run scripts/test-init-action.js",
    "test-event-action": "bun run scripts/test-event-action.js",
    "test-heartbeat-action": "bun run scripts/test-heartbeat-action.js",
    "test-identify-action": "bun run scripts/test-identify-action.js",
    "test-retroactive-linking": "bun run scripts/test-retroactive-linking.js",
    "test-confidence-score": "bun run scripts/test-confidence-score.js",
    "test-phase3": "bun run test-init-action && bun run test-event-action && bun run test-heartbeat-action && bun run test-identify-action && bun run test-retroactive-linking && bun run test-confidence-score",
    "prepare": "husky"
  },
  "dependencies": {
    "@cerebras/cerebras_cloud_sdk": "^1.64.1",
    "@neondatabase/serverless": "^1.0.2",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.21",
    "cors": "^2.8.6",
    "dompurify": "^3.3.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "framer-motion": "^12.35.2",
    "highlight.js": "^11.11.1",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "lenis": "^1.3.18",
    "prop-types": "^15.8.1",
    "quill": "^2.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.6.0",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-quill": "^2.0.0",
    "react-router-dom": "^7.13.1",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "ua-parser-js": "^2.0.9",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "playwright": "^1.58.2",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "terser": "^5.46.0",
    "vite": "7.3.1",
    "vite-imagetools": "^9.0.3",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-pwa": "^1.2.0"
  }
}
